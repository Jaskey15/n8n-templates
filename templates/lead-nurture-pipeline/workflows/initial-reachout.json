        "jsCode": "// Extract customer data from GHL webhook\nconst body = $input.item.json.body;\nconst customData = body.customData || {};\nreturn {\n  json: {\n    contact_id: body.contact_id,\n    first_name: customData.first_name,\n    asset_description: customData.asset_description,\n    vehicle: customData.vehicle,\n    services_interested: customData.services_interested,\n    services_interested_check: customData.services_interested_check,\n    desired_packages: customData.desired_packages,\n    additional_info: customData.message_notes,\n  }\n};"
