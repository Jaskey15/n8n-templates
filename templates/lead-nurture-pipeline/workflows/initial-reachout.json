    {
      "parameters": {
        "jsCode": "// Format conversation history for GPT-5 (SMS ONLY)\nconst messagesData = $('Get Conversation History').item.json.messages || {};\nconst allMessages = messagesData.messages || [];\nconst customerData = $('Parse Customer Data').item.json;\n\n// Filter to SMS messages only (exclude emails, calls, etc.)\nconst smsMessages = allMessages.filter(msg => \n  msg.messageType === 'TYPE_SMS' || msg.messageType === 'SMS'\n);\n\n// Reverse to chronological order \nconst sortedMessages = [...smsMessages].reverse();\n\n// Format as conversation history with line breaks between messages\nconst conversationHistory = sortedMessages.map(msg => {\n  const role = msg.direction === 'inbound' ? customerData.first_name : '{{YOUR_AI_AGENT_NAME}}';\n  let content = msg.body || '';\n  \n  // Handle attachments (prevents blank messages when customers send images)\n  if (msg.attachments && msg.attachments.length > 0 && !content) {\n    content = '[Customer sent an image]';\n  }\n  \n  return `${role}: ${content}`;\n}).join('\\n\\n');\n\n// Helper function to provide fallback for empty/missing values\nconst notProvided = (value) => value || '(not provided)';\n\nreturn {\n  json: {\n    conversation_history: conversationHistory,\n    contact_id: customerData.contact_id,\n    first_name: notProvided(customerData.first_name),\n    asset_description: notProvided(customerData.asset_description),\n    vehicle: notProvided(customerData.vehicle),\n    services_interested: notProvided(customerData.services),\n    services_interested_check: notProvided(customerData.services_interested_check),\n    desired_packages: notProvided(customerData.desired_packages),\n    additional_info: notProvided(customerData.additional_info),\n  }\n};"
      },
