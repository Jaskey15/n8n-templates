      "id": "ee77f017-595d-471f-8d4c-30fee6c753f5",
      "name": "Generate Message"
    },
    {
      "parameters": {
        "jsCode": "// Calculate business hours context (for handoff timing)\nconst now = new Date().toLocaleString('en-US', { timeZone: 'YOUR_TIMEZONE' });\nconst date = new Date(now);\nconst day = date.getDay();\nconst hour = date.getHours();\nlet timeContext;\nif (day === 0 || day === 6 || (day === 5 && hour >= 17)) {\n  timeContext = \"WEEKEND\";\n} else if (hour >= 17) {\n  timeContext = \"AFTER_HOURS\";\n} else {\n  timeContext = \"BUSINESS_HOURS\";\n}\n\nreturn { timeContext };"
      },
      "type": "n8n-nodes-base.code",
