    {
      "parameters": {
        "content": "Chatbot Flow\n\n1. Webhook receives customer message\n2. Parse customer data from GHL\n3. HTTP GET conversation history\n4. Format history for GPT-5 context\n5. GPT-5 generates response\n   - Can call trigger_handoff function\n6. IF node checks for handoff\n7a. Normal: Send SMS response\n7b. Handoff: Add tag + Send message\n8. Respond to webhook\n",
        "height": 280,
        "width": 308,
        "color": 4
      },
      "id": "7caf5d05-12dc-4427-a532-e74745f9a4e6",
      "name": "Sticky Note",
