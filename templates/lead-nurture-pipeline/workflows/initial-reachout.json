    {
      "parameters": {
        "jsCode": "// Strip ##HANDOFF## marker from LLM response\nconst llmResponse = $input.item.json.text || '';\n\nreturn {\n  json: {\n    ...$input.item.json,\n    text: llmResponse.replace('##HANDOFF##', '').trim()\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1344,
        -240
      ],
      "id": "148b43fe-d08e-4b28-a696-90cc2da2f04f",
      "name": "Trim Message"
    },
    {
      "parameters": {
        "jsCode": "// Get all messages \nconst messages = $input.item.json.messages.messages || [];\n\nif (!messages || messages.length === 0) {\n  return { json: { shouldStop: false, reason: 'no_messages' } };\n}\n\n// Known human userIds from GHL team ({{YOUR_BUSINESS_NAME}})\nconst HUMAN_IDS = [\n  'YOUR_EMPLOYEE_2_USER_ID', // {{YOUR_EMPLOYEE_NAME}}\n  'YOUR_EMPLOYEE_1_USER_ID', // {{YOUR_EMPLOYEE_NAME}} ({{YOUR_DOMAIN}})\n  'YOUR_EMPLOYEE_3_USER_ID', // {{YOUR_EMPLOYEE_NAME}} ({{YOUR_DOMAIN}})\n  'YOUR_EMPLOYEE_4_USER_ID', // {{YOUR_EMPLOYEE_NAME}}\n];\n\n// Check if ANY call exists (inbound or outbound, regular or IVR)\n// The AI agent never makes calls, so any call = human intervention\nconst hasHumanCall = messages.some(msg => \n  msg.messageType === 'TYPE_CALL' || msg.messageType === 'TYPE_IVR_CALL'\n);\n\n// Check if ANY human sent an SMS (must check userId since {{YOUR_AI_AGENT_NAME}} also sends SMS)\nconst hasHumanSMS = messages.some(msg => \n  msg.messageType === 'TYPE_SMS' && \n  msg.direction === 'outbound' &&\n  msg.userId && \n  HUMAN_IDS.includes(msg.userId)\n);\n\nconst shouldStop = hasHumanCall || hasHumanSMS;\n\nlet reason = 'none';\nif (hasHumanCall) reason = 'human_call_detected';\nif (hasHumanSMS) reason = 'human_sms_detected';\nif (hasHumanCall && hasHumanSMS) reason = 'multiple_human_interventions';\n\nreturn { \n  json: { \n    shouldStop,\n    reason,\n    hasHumanCall,\n    hasHumanSMS\n  } \n};"
      },
